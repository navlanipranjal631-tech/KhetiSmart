# ─────────────────────────────────────────────────────────────────────────────
# KhetiSmart — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it's in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── ThingSpeak IoT Sensor API ─────────────────────────────────────────────────
# Get these from: https://thingspeak.com → My Channels → your channel → API Keys
# Leave blank to run in Simulation Mode (demo-safe, looks identical on screen)
VITE_THINGSPEAK_CHANNEL_ID=
VITE_THINGSPEAK_READ_KEY=

# ── Agmarknet / data.gov.in ───────────────────────────────────────────────────
# Get a free key at: https://data.gov.in → Login → My Account → API Keys
# A public demo key is used as fallback if this is blank.
VITE_AGMARKNET_KEY=
